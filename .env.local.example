# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Finance API (FastAPI / Render) ───────────────────────────────────────────
FINANCE_API_URL=http://localhost:8000

# ── Anthropic (KI-Analyse, Vera, Opus, NH-Select) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── App URL (wird in Cron-Routen für interne Aufrufe benötigt) ───────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron-Jobs (Vercel Cron ruft Routen mit diesem Secret auf) ───────────────
CRON_SECRET=your-cron-secret

# ── Jina AI (Artikel-Auszüge für Vera & Nina) ───────────────────────────────
JINA_API_KEY=jina_...

# ── Web Push Notifications (VAPID-Keys) ─────────────────────────────────────
# Generieren: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:deine@email.com

# ── Resend (E-Mail-Benachrichtigungen bei Kurs-Alarmen, optional) ────────────
RESEND_API_KEY=re_...
ALERT_FROM_EMAIL=alerts@yourdomain.com
